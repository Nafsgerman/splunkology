ANTHROPIC_API_KEY=your_anthropic_key_here

# Splunk connection
SPLUNK_URL=https://localhost:8089
SPLUNK_USER=admin
SPLUNK_PASS=your_splunk_password_here

# Agent config
SPLUNKOLOGY_MODEL=claude-sonnet-4-6
SPLUNKOLOGY_PROMPT_VERSION=v2
SPLUNKOLOGY_MAX_AGENT_ITERATIONS=15
SPLUNKOLOGY_LOG_LEVEL=INFO
SPLUNKOLOGY_AUDIT_DB=./audit/splunkology.db
